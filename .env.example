DATABASE_URL="postgresql://onevideo:onevideo@localhost:5432/onevideo?schema=public"
REDIS_URL="redis://localhost:6379"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Clerk Auth (https://clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard/projects
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard/projects

ONEAI_BASE_URL="https://oneai-saas-web-production.up.railway.app"
ONEAI_API_KEY=""
MOCK_AI="true"

VIDEO_PROVIDER="mock"
VIDEO_PROVIDER_FALLBACK_TO_MOCK="false"
VIDEO_PROVIDER_FALLBACK_CHAIN=""
RUNWAY_API_KEY=""
RUNWAY_BASE_URL="https://api.dev.runwayml.com"
RUNWAY_MODEL="gen4_turbo"
RUNWAY_POLL_INTERVAL_MS="10000"
RUNWAY_POLL_ATTEMPTS="30"
RUNWAY_RATE_LIMIT_RETRIES="3"
RUNWAY_RATE_LIMIT_DELAY_MS="15000"
KLING_BASE_URL="https://api-singapore.klingai.com"
KLING_API_KEY=""
KLING_MODEL="kling-v3"
KLING_MODE="pro"
VIDEO_PROVIDER_USE_IMAGE_TO_VIDEO="false"
KLING_IMAGE_TO_VIDEO_PATH="/v1/videos/image2video"
KLING_IMAGE_FIELD="image_url"
KLING_SCENE_MAX_SECONDS="10"
KLING_POLL_ID_TYPE="task_id"
KLING_STATUS_PATH="/v1/videos/text2video/{taskId}"
KLING_POLL_ATTEMPTS="24"
KLING_POLL_INTERVAL_MS="5000"

TTS_PROVIDER="system"
SYSTEM_TTS_VOICE=""
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com"
OPENAI_TTS_MODEL="gpt-4o-mini-tts"
OPENAI_TTS_VOICE="alloy"

IMAGE_PROVIDER="placeholder"
IMAGE_PROVIDER_FALLBACK_TO_PLACEHOLDER="true"
IMAGE_BASE_URL="https://api.openai.com"
IMAGE_API_KEY=""
IMAGE_MODEL="gpt-image-1"
IMAGE_SIZE="1024x1536"

STORAGE_PROVIDER="local"
STORAGE_PUBLIC_BASE_URL=""
STORAGE_UPLOAD_BASE_URL=""
STORAGE_UPLOAD_TOKEN=""
PUBLIC_ASSET_BASE_URL=""
ALLOW_LOCAL_PROVIDER_ASSETS="false"

# ElevenLabs 声音克隆
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_VOICE_STABILITY=0.5
ELEVENLABS_VOICE_SIMILARITY=0.75

# Stripe 计费
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_TEAM_PRICE_ID=
STRIPE_PACK_500_PRICE_ID=
STRIPE_PACK_2000_PRICE_ID=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

FFMPEG_PATH="ffmpeg"
SUBTITLE_BURN="false"
SUBTITLE_FONT_SIZE="18"

PROJECT_WORKER_CONCURRENCY="1"
SCENE_VIDEO_WORKER_CONCURRENCY="1"
RENDER_WORKER_CONCURRENCY="1"
PROJECT_WORKFLOW_ATTEMPTS="2"
PROJECT_WORKFLOW_BACKOFF_MS="5000"
SCENE_VIDEO_ATTEMPTS="1"
SCENE_VIDEO_BACKOFF_MS="10000"
SCENE_STAGGER_MS="5000"
RENDER_ATTEMPTS="1"
RENDER_BACKOFF_MS="10000"
PROVIDER_TASK_SPLIT="true"
PROVIDER_POLL_ATTEMPTS="60"
PROVIDER_POLL_INTERVAL_MS="10000"
VIDEO_QA_EXTRACT_FRAME="true"
VIDEO_QUALITY_MIN_SCORE="70"
VIDEO_QUALITY_BLOCK_RENDER="false"
VIDEO_QUALITY_AUTO_RETRY="false"
VIDEO_QUALITY_AUTO_RETRY_LIMIT="1"
WORKER_HEARTBEAT_INTERVAL_MS="10000"
WORKER_STALE_AFTER_SECONDS="30"
