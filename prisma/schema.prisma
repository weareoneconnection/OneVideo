generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String    @id @default(uuid())
  email            String    @unique
  name             String?
  stripeCustomerId String?   @unique
  stripePlanId     String?
  stripeSubId      String?
  planExpiresAt    DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  projects      Project[]
  credits       CreditAccount?
  ledger        CreditLedger[]
  voiceProfiles VoiceProfile[]
}

model CreditAccount {
  id        String   @id @default(uuid())
  userId    String   @unique
  balance   Int      @default(1000)
  locked    Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CreditLedger {
  id          String   @id @default(uuid())
  userId      String
  projectId   String?
  amount      Int
  type        String
  status      String
  description String?
  createdAt   DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
}

model Project {
  id              String   @id @default(uuid())
  userId          String
  title           String?
  topic           String
  platform        String
  language        String
  aspectRatio     String
  durationSeconds Int
  style           String?
  voiceProfileId  String?
  status          String   @default("created")
  progress        Int      @default(0)
  workflowJobId   String?
  renderJobId     String?
  scriptJson      Json?
  visualBibleJson Json?
  directorNotesJson Json?
  finalVideoUrl   String?
  thumbnailUrl    String?
  totalCostCredits Int     @default(0)
  errorMessage    String?
  queuedAt        DateTime?
  startedAt       DateTime?
  renderedAt      DateTime?
  completedAt     DateTime?
  failedAt        DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  voiceProfile VoiceProfile?  @relation(fields: [voiceProfileId], references: [id], onDelete: SetNull)
  scenes       Scene[]
  assets       Asset[]
  modelTasks   ModelTask[]
  creditLogs   CreditLedger[]
}

model Scene {
  id              String   @id @default(uuid())
  projectId       String
  sceneIndex      Int
  durationSeconds Int
  voiceover       String
  visualPrompt    String
  videoPrompt     String?
  cameraMotion    String?
  mood            String?
  location        String?
  storyBeat       String?
  entryState      String?
  exitState       String?
  continuityNote  String?
  continuityAnchor String?
  transitionFromPrevious String?
  referenceImageUrl String?
  firstFrameUrl   String?
  qualityScore    Int?
  reviewStatus    String?  @default("pending")
  qualityNotes    String?
  status          String   @default("pending")
  videoJobId      String?
  imageUrl        String?
  videoUrl        String?
  provider        String?
  model           String?
  externalTaskId  String?
  rawStatus       String?
  costCredits     Int      @default(0)
  errorMessage    String?
  queuedAt        DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  failedAt        DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assets     Asset[]
  modelTasks ModelTask[]
}

model Asset {
  id        String   @id @default(uuid())
  projectId String
  sceneId   String?
  type      String
  url       String
  mimeType  String?
  sizeBytes Int?
  metadata  Json?
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  scene   Scene?  @relation(fields: [sceneId], references: [id], onDelete: SetNull)
}

model ModelTask {
  id             String   @id @default(uuid())
  projectId      String
  sceneId        String?
  queueJobId     String?
  provider       String
  model          String
  taskType       String
  externalTaskId String?
  status         String
  rawStatus      String?
  attempt        Int      @default(1)
  maxAttempts    Int      @default(1)
  inputJson      Json?
  outputJson     Json?
  costUsd        Decimal?
  latencyMs      Int?
  errorMessage   String?
  startedAt      DateTime?
  completedAt    DateTime?
  failedAt       DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  scene   Scene?  @relation(fields: [sceneId], references: [id], onDelete: SetNull)
}

model Template {
  id          String   @id @default(uuid())
  name        String
  description String?
  category    String
  platform    String
  language    String
  duration    Int
  structure   Json
  prompt      String
  isPublic    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BrandKit {
  id          String   @id @default(uuid())
  userId      String
  name        String
  logoUrl     String?
  colors      Json?
  fonts       Json?
  toneOfVoice String?
  defaultCTA  String?
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model WorkerHeartbeat {
  id         String   @id @default(uuid())
  name       String   @unique
  queueName  String
  status     String   @default("online")
  metadata   Json?
  lastSeenAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model VoiceProfile {
  id                String   @id @default(uuid())
  userId            String
  name              String
  elevenLabsVoiceId String
  sampleUrl         String?
  language          String   @default("zh")
  isDefault         Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects Project[]
}
